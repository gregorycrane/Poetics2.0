# sentence_id = 78
# document_id = 0086-034
# subdoc = 6.12
# translation_lang = en
# prose_translation = Most important of these is the arrangement of the incidents. For Tragedy is an imitation, not of men, but of an action and of life. [And happiness and misery consist in action, and the end is a certain action, not a quality; and it is according to their characters that men are of a certain quality, but according to their actions they are happy or the contrary.]
# literal_translation = But the greatest of these is the composition of the things. For the tragedy is an imitation not of men but of actions and of life [and happiness and misery is in action, and the end is a certain action, not quality; but they are certain sorts according to the characters, but according to the actions happy or the contrary].
