# sentence_id = 193
# document_id = 0086-034
# subdoc = 15.10c
# translation_lang = en
# prose_translation = The machine should be used for things outside the play, either events that happened before which a human being could not know, or later ones that need to be predicted and reported; for we attribute to the gods the power to see all things.
