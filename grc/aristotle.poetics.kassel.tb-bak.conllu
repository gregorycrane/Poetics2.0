# sentence_id = 59
# document_id = 0086-034
# subdoc = 4.14
# translation_lang = en
# prose_translation = Having originated, then, in improvisation—both Tragedy and Comedy, the former from the leaders of the Dithyramb, the latter from the leaders of the phallic songs which still survive as a custom in many of our cities—Tragedy grew by gradual development as men advanced as much as was manifest of it.
# literal_translation = Having-become but therefore from beginning improvisational—both itself and the comedy, and the indeed from the ones-leading the dithyramb, the but from the the phallic-things which still and now in many of the cities remain being-customary—according to little was-increased of-those-leading as-much-as was-becoming manifest of-it;
